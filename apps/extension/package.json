{
  "name": "@nicodemus/extension",
  "displayName": "Nicodemus Student Edge",
  "version": "1.0.0",
  "description": "Browser extension for tracking student focus and productivity",
  "author": "Nicodemus",
  "manifest": {
    "permissions": ["tabs", "idle", "alarms"],
    "host_permissions": ["<all_urls>"]
  },
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.292.0",
    "@plasmohq/storage": "^1.13.0"
  },
  "devDependencies": {
    "plasmo": "^0.90.5",
    "@types/chrome": "^0.0.251",
    "@types/node": "^20.10.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "vitest": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  }
}
