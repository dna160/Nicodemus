{
  "name": "nicodemus-student-rep",
  "version": "0.1.0",
  "description": "Student Rep Agent - Browser extension for tracking study behavior",
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^3.2.0",
    "@testing-library/react": "^14.0.0",
    "@types/chrome": "^0.0.246",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "plasmo": "^0.87.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zustand": "^4.4.0"
  },
  "manifest": {
    "host_permissions": [
      "https://*/",
      "http://*/"
    ],
    "permissions": [
      "tabs",
      "activeTab",
      "scripting",
      "storage",
      "webRequest"
    ]
  }
}
