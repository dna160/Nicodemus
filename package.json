{
  "name": "nicodemus",
  "version": "0.1.0",
  "description": "Enterprise Educational AI Suite - Privacy-First Multi-Agent System for Schools",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "edge/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "type-check": "pnpm -r run type-check",
    "lint": "pnpm -r run lint",
    "db:push": "pnpm exec supabase db push",
    "db:pull": "pnpm exec supabase db pull",
    "db:status": "pnpm exec supabase status",
    "modal:deploy": "modal deploy modal_app.py",
    "setup": "pnpm install && pnpm run type-check"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "supabase": "^1.131.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "keywords": [
    "education",
    "ai",
    "privacy",
    "ferpa",
    "schools",
    "coppa",
    "gdpr"
  ],
  "author": "Nicodemus Team",
  "license": "PROPRIETARY"
}
